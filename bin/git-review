  }

  /* diff2html overrides for dark theme */
  .d2h-wrapper { background: transparent !important; }
  .d2h-file-wrapper {
    border: 1px solid var(--border) !important;
    border-radius: 6px !important;
    margin-bottom: 16px !important;
    background: var(--bg-secondary) !important;
  }
  .d2h-file-header {
    background: var(--bg-secondary) !important;
    border-bottom: 1px solid var(--border) !important;
    padding: 8px 12px !important;
  }
  .d2h-file-name-wrapper { color: var(--text) !important; }
  .d2h-file-name { color: var(--text) !important; }
  .d2h-code-line, .d2h-code-side-line {
    color: var(--text) !important;
    background: var(--bg) !important;
    padding-left: 4px !important;
  }
  .d2h-code-line-ctn { color: var(--text) !important; }
  .d2h-code-linenumber {
    color: var(--text-muted) !important;
    background: var(--bg-secondary) !important;
    border-right: 1px solid var(--border) !important;
    cursor: pointer;
  }
  .d2h-code-linenumber:hover {
    background: rgba(88,166,255,0.2) !important;
  }
  .d2h-del {
    background: rgba(248,81,73,0.15) !important;
  }
  .d2h-ins {
    background: rgba(63,185,80,0.15) !important;
  }
  .d2h-del .d2h-code-line-ctn del {
    background: rgba(248,81,73,0.3) !important;
    color: var(--text) !important;
  }
  .d2h-ins .d2h-code-line-ctn ins {
    background: rgba(63,185,80,0.3) !important;
    color: var(--text) !important;
    text-decoration: none !important;
  }
  .d2h-info {
    background: rgba(88,166,255,0.1) !important;
    color: var(--text-muted) !important;
    border-color: var(--border) !important;
  }
  .d2h-emptyplaceholder { background: var(--bg) !important; }
  .d2h-tag {
    background: var(--bg) !important;
    color: var(--text-muted) !important;
  }
  .d2h-file-diff { overflow-x: auto !important; }
  .d2h-file-side-diff { overflow-x: auto !important; }
  table.d2h-diff-table {
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace !important;
