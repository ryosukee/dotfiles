  .modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    margin-top: 12px;
  }
</style>
</head>
<body>

<div class="header">
  <span class="header-title">${REPO_NAME}</span>
  <span class="header-meta">${BRANCH} @ ${SHORT_SHA}</span>
  <span id="total-comment-count" class="comment-count" style="display:none">0</span>
  <div class="header-actions">
    <div class="view-toggle">
      <button id="btn-side" class="active" onclick="setView('side-by-side')">Side by side</button>
      <button id="btn-line" onclick="setView('line-by-line')">Unified</button>
    </div>
    <button class="btn" onclick="exportMarkdown()">Export MD</button>
    <button class="btn" onclick="clearAllComments()">Clear all</button>
  </div>
</div>

<div class="sidebar">
  <h3>Changed files</h3>
  <ul id="file-list" class="file-list"></ul>
</div>

<div class="main" id="diff-container"></div>

<div class="modal-overlay" id="export-modal">
  <div class="modal">
    <h2>Export as Markdown</h2>
    <pre id="export-content"></pre>
    <div class="modal-actions">
      <button class="btn" onclick="closeModal()">Close</button>
      <button class="btn btn-primary" onclick="copyExport()">Copy to clipboard</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/diff2html/bundles/js/diff2html-ui.min.js"></script>
<script>
const rawDiff = ${DIFF_JSON};
const rawStat = ${STAT_JSON};
const STORAGE_KEY = 'git-review:' + ${REPO_NAME@Q} + ':' + ${BRANCH@Q};

let currentView = 'side-by-side';
let comments = loadComments();

function loadComments() {
  try {
    return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
  } catch { return {}; }
}

function saveComments() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(comments));
  updateCommentCounts();
}

function renderDiff() {
  const container = document.getElementById('diff-container');
  const config = {
    drawFileList: false,
    matching: 'lines',
    outputFormat: currentView,
    highlight: true,
    colorScheme: 'dark',
  };
  const diff2htmlUi = new Diff2HtmlUI(container, rawDiff, config);
  diff2htmlUi.draw();
  diff2htmlUi.highlightCode();
  attachLineClickHandlers();
  renderExistingComments();
}

function setView(view) {
  currentView = view;
  document.getElementById('btn-side').classList.toggle('active', view === 'side-by-side');
  document.getElementById('btn-line').classList.toggle('active', view === 'line-by-line');
  renderDiff();
}

// Parse file list from diff
function parseFiles() {
  const files = [];
  const lines = rawDiff.split('\n');
  for (const line of lines) {
    const match = line.match(/^diff --git a\/(.*) b\/(.*)/);
    if (match) {
      files.push({ from: match[1], to: match[2] });
    }
  }
  return files;
}

function getFileStatus(file) {
  if (file.from === '/dev/null' || file.from !== file.to) {
    if (rawDiff.includes('new file mode')) return 'added';
    if (rawDiff.includes('deleted file mode')) return 'deleted';
    if (file.from !== file.to) return 'renamed';
  }
  return 'modified';
}

function buildFileList() {
  const list = document.getElementById('file-list');
  const files = parseFiles();
  list.innerHTML = '';
  files.forEach((file, i) => {
    const name = file.to === '/dev/null' ? file.from : file.to;
    const status = getFileStatus(file);
    const li = document.createElement('li');
    li.className = 'file-item';
    li.dataset.file = name;
    li.innerHTML =
      '<span class="filename" title="' + name + '">' + name.split('/').pop() + '</span>' +
      '<span class="badge badge-' + status + '">' + status[0].toUpperCase() + '</span>' +
      '<span class="file-comment-count" style="display:none" data-file-count="' + name + '"></span>';
    li.onclick = () => scrollToFile(name);
    list.appendChild(li);
  });
  updateCommentCounts();
}

function scrollToFile(name) {
  const headers = document.querySelectorAll('.d2h-file-name');
  for (const h of headers) {
    if (h.textContent.trim().includes(name.split('/').pop())) {
      h.closest('.d2h-file-wrapper').scrollIntoView({ behavior: 'smooth', block: 'start' });
      break;
    }
  }
}

// Inline comment handling
function getLineKey(fileEl, lineEl) {
  const fileName = fileEl.querySelector('.d2h-file-name')?.textContent?.trim() || 'unknown';
  const lineNum = lineEl.querySelector('.d2h-code-linenumber')?.textContent?.trim() || '?';
  return fileName + ':' + lineNum;
}

function attachLineClickHandlers() {
  document.querySelectorAll('.d2h-file-wrapper').forEach(fileEl => {
    fileEl.querySelectorAll('tr').forEach(tr => {
      const lineNumCells = tr.querySelectorAll('.d2h-code-linenumber');
      lineNumCells.forEach(cell => {
        cell.addEventListener('click', (e) => {
          e.preventDefault();
          const key = getLineKey(fileEl, tr);
          showCommentForm(tr, fileEl, key);
        });
      });
    });
  });
}

function showCommentForm(tr, fileEl, key) {
  // Remove any existing form
  document.querySelectorAll('.comment-form').forEach(f => f.remove());

  const form = document.createElement('tr');
  form.innerHTML = '<td colspan="99"><div class="comment-form">' +
    '<textarea placeholder="Add a review comment... (Cmd+Enter to submit)" autofocus></textarea>' +
    '<div class="comment-form-actions">' +
    '<button class="btn" onclick="this.closest(\'tr\').remove()">Cancel</button>' +
    '<button class="btn btn-primary" data-key="' + key.replace(/"/g, '&quot;') + '">Comment</button>' +
    '</div></div></td>';

  tr.parentNode.insertBefore(form, tr.nextSibling);

  const textarea = form.querySelector('textarea');
  textarea.focus();
  textarea.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
      addComment(key, textarea.value, form, fileEl);
    }
  });
  form.querySelector('.btn-primary').addEventListener('click', () => {
    addComment(key, textarea.value, form, fileEl);
  });
}

function addComment(key, text, formRow, fileEl) {
  if (!text.trim()) return;
  if (!comments[key]) comments[key] = [];
  comments[key].push({
    text: text.trim(),
    timestamp: new Date().toISOString(),
  });
  saveComments();
  formRow.remove();
  renderExistingComments();
}

function renderExistingComments() {
  // Remove existing rendered comments
  document.querySelectorAll('.inline-comment-row').forEach(r => r.remove());

  document.querySelectorAll('.d2h-file-wrapper').forEach(fileEl => {
    fileEl.querySelectorAll('tr').forEach(tr => {
      const key = getLineKey(fileEl, tr);
      if (comments[key] && comments[key].length > 0) {
        comments[key].forEach((c, idx) => {
          const row = document.createElement('tr');
          row.className = 'inline-comment-row';
          const time = new Date(c.timestamp).toLocaleString();
          row.innerHTML = '<td colspan="99"><div class="inline-comment">' +
            '<div class="comment-header"><span>' + key + ' &middot; ' + time + '</span>' +
            '<button class="comment-delete" data-key="' + key.replace(/"/g, '&quot;') + '" data-idx="' + idx + '">&times;</button></div>' +
            '<div class="comment-body">' + escapeHtml(c.text) + '</div></div></td>';
          row.querySelector('.comment-delete').addEventListener('click', (e) => {
            deleteComment(key, idx);
          });
          tr.parentNode.insertBefore(row, tr.nextSibling);
        });
      }
    });
  });
}

function deleteComment(key, idx) {
  if (comments[key]) {
    comments[key].splice(idx, 1);
    if (comments[key].length === 0) delete comments[key];
    saveComments();
    renderExistingComments();
  }
}

function updateCommentCounts() {
  let total = 0;
  // Reset file counts
  document.querySelectorAll('[data-file-count]').forEach(el => {
    el.style.display = 'none';
    el.textContent = '0';
  });
  for (const [key, arr] of Object.entries(comments)) {
    total += arr.length;
    const fileName = key.split(':')[0];
    const el = document.querySelector('[data-file-count="' + fileName + '"]');
    if (el) {
      const cur = parseInt(el.textContent) + arr.length;
      el.textContent = cur;
      el.style.display = 'inline';
    }
  }
  const badge = document.getElementById('total-comment-count');
  badge.textContent = total;
  badge.style.display = total > 0 ? 'inline' : 'none';
}

function clearAllComments() {
  if (!confirm('Clear all comments?')) return;
  comments = {};
  saveComments();
  renderExistingComments();
}

// Export
function exportMarkdown() {
  const lines = ['# Review: ${REPO_NAME} (${BRANCH} @ ${SHORT_SHA})\n'];
  const grouped = {};
  for (const [key, arr] of Object.entries(comments)) {
    const file = key.split(':')[0];
    if (!grouped[file]) grouped[file] = [];
    arr.forEach(c => grouped[file].push({ line: key.split(':').slice(1).join(':'), ...c }));
  }
  for (const [file, items] of Object.entries(grouped)) {
    lines.push('## ' + file + '\n');
    items.forEach(c => {
      lines.push('- **L' + c.line + '**: ' + c.text);
    });
    lines.push('');
  }
  if (Object.keys(grouped).length === 0) {
    lines.push('_No comments._');
  }
  const md = lines.join('\n');
  document.getElementById('export-content').textContent = md;
  document.getElementById('export-modal').classList.add('active');
}

function copyExport() {
  const text = document.getElementById('export-content').textContent;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector('#export-modal .btn-primary');
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy to clipboard'; }, 1500);
  });
}

function closeModal() {
  document.getElementById('export-modal').classList.remove('active');
}

// Close modal on overlay click
document.getElementById('export-modal').addEventListener('click', (e) => {
  if (e.target === e.currentTarget) closeModal();
});

function escapeHtml(str) {
  const div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}

// Init
buildFileList();
renderDiff();
</script>
</body>
</html>
HTMLEOF

echo "Review opened: $OUTPUT"

# Open in browser
if command -v open &>/dev/null; then
  open "$OUTPUT"
elif command -v xdg-open &>/dev/null; then
  xdg-open "$OUTPUT"
else
  echo "Open $OUTPUT in your browser"
fi
