#!/usr/bin/env bash
set -euo pipefail

# git-review: Local PR-style diff review with inline comments
# Place in PATH as "git-review" to use as "git review"

VERSION="0.1.0"
REVIEW_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/git-review"

usage() {
  cat <<'USAGE'
Usage: git review [options] [<commit>] [-- <path>...]

  git review              # working tree vs HEAD
  git review --staged     # staged changes vs HEAD
  git review main         # working tree vs main
  git review main..HEAD   # commits between main and HEAD
  git review HEAD~3..HEAD # last 3 commits

Options:
  -s, --staged    Review staged changes only
  -o, --output    Save HTML to specified path instead of temp file
  -h, --help      Show this help
  -v, --version   Show version
USAGE
}

# Parse arguments
STAGED=false
OUTPUT=""
DIFF_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -s|--staged) STAGED=true; shift ;;
    -o|--output) OUTPUT="$2"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    -v|--version) echo "git-review $VERSION"; exit 0 ;;
    --) shift; DIFF_ARGS+=("--" "$@"); break ;;
    *) DIFF_ARGS+=("$1"); shift ;;
  esac
done

# Must be in a git repo
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo "Error: not a git repository" >&2
  exit 1
fi

REPO_NAME=$(basename "$(git rev-parse --show-toplevel)")
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "detached")
SHORT_SHA=$(git rev-parse --short HEAD 2>/dev/null || echo "none")

# Build git diff command
DIFF_CMD=(git diff --no-color)
if $STAGED; then
  DIFF_CMD+=(--cached)
fi
DIFF_CMD+=("${DIFF_ARGS[@]}")

# Get the diff
DIFF_OUTPUT=$("${DIFF_CMD[@]}")
if [[ -z "$DIFF_OUTPUT" ]]; then
  echo "No changes to review."
  exit 0
fi

# Build diff summary for sidebar
DIFF_STAT=$(git diff --stat --no-color $($STAGED && echo "--cached") "${DIFF_ARGS[@]}" 2>/dev/null || true)

# Determine output path
if [[ -z "$OUTPUT" ]]; then
  OUTPUT=$(mktemp /tmp/git-review-XXXXXX.html)
fi

# Escape content for embedding in HTML
escape_for_js() {
  python3 -c "
import sys, json
data = sys.stdin.read()
print(json.dumps(data))
"
}

DIFF_JSON=$(echo "$DIFF_OUTPUT" | escape_for_js)
STAT_JSON=$(echo "$DIFF_STAT" | escape_for_js)

# Generate HTML
cat > "$OUTPUT" <<HTMLEOF
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Review: ${REPO_NAME} (${BRANCH})</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/diff2html/bundles/css/diff2html.min.css">
<style>
  :root {
    --sidebar-width: 300px;
    --header-height: 48px;
